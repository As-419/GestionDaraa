<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<!--
  Configuration de TEST : base H2 en memoire (mode compatibilite PostgreSQL).
  Ce fichier (dans src/test/resources) masque celui de src/main/resources
  pendant la phase de test : aucun PostgreSQL ni Docker requis pour les tests.
-->
<hibernate-configuration>
    <session-factory>
        <property name="hibernate.dialect">org.hibernate.dialect.H2Dialect</property>
        <property name="hibernate.connection.driver_class">org.h2.Driver</property>
        <property name="hibernate.connection.url">jdbc:h2:mem:daara_test;DB_CLOSE_DELAY=-1;MODE=PostgreSQL</property>
        <property name="hibernate.connection.username">sa</property>
        <property name="hibernate.connection.password"></property>

        <property name="hibernate.hbm2ddl.auto">create-drop</property>
        <property name="hibernate.show_sql">false</property>

        <mapping class="sn.l2gl.aida.daara.model.models.Maitre"/>
        <mapping class="sn.l2gl.aida.daara.model.models.Classe"/>
        <mapping class="sn.l2gl.aida.daara.model.models.Talibe"/>
        <mapping class="sn.l2gl.aida.daara.model.models.Progression"/>
    </session-factory>
</hibernate-configuration>
